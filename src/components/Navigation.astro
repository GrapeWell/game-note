---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getGameLogo } from '../utils/games';
import { Tag } from '@lucide/astro'

// 获取所有文章
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// 按游戏分组
const gameGroups = allPosts.reduce((acc, post) => {
  const game = post.data.category;
  if (!acc[game]) {
    acc[game] = [];
  }
  acc[game].push(post);
  return acc;
}, {} as Record<string, typeof allPosts>);

// 获取游戏列表
const games = Object.entries(gameGroups).map(([game, posts]) => ({
  game,
  count: posts.length,
  logo: getGameLogo(game)
}));
---

<nav class="space-y-2">
  <!-- 所有标签链接 -->
  <a
    href="/tags"
    data-navlink
    class="px-3 py-2 text-text-primary font-medium hover:bg-bg-hover rounded-lg flex items-center gap-2"
  >
    <Tag class="w-4 h-4"/>
    <span>所有标签</span>
  </a>

  <div class="border-t border-border-muted my-2"></div>

  <!-- 游戏列表 - 一级菜单 -->
  {games.map(({ game, count, logo }) => (
    <a
      href={`/game/${game}`}
      data-navlink
      class="px-3 py-2 text-text-primary font-medium hover:bg-bg-hover rounded-lg flex items-center justify-between group"
    >
      <div class="flex items-center gap-2">
        {logo ? (
          <Image
            src={logo}
            alt={game}
            class="w-5 h-5 object-contain"
            loading="eager"
          />
        ) : (
          <div class="w-5 h-5 bg-bg-muted rounded flex items-center justify-center text-xs">
            {game.charAt(0)}
          </div>
        )}
        <span class="group-hover:text-text-accent transition-colors">{game}</span>
      </div>
      <span class="text-xs text-text-faint">{count}</span>
    </a>
  ))}
</nav>

<script>
  function updateActiveLinks() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('[data-navlink]').forEach(link => {
      const href = link.getAttribute('href') ?? '';
      link.classList.toggle('nav-link-active', path === href || path.startsWith(href + '/'));
    });
  }

  // 初始化
  updateActiveLinks();

  // View Transitions 后更新激活状态
  document.addEventListener('astro:after-swap', updateActiveLinks);
</script>
