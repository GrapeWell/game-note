---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { ClientRouter } from "astro:transitions";
import Search from "astro-pagefind/components/Search";
import { X, Search as SearchIcon } from "@lucide/astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: Date;
  tags?: string[];
}

const {
  title = "游戏手札",
  description = "记录游戏攻略与心得",
  image,
  article,
  publishedTime,
  tags,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
      publishedTime={publishedTime}
      tags={tags}
    />
    <!-- 主题初始化脚本 - 防止闪烁 -->
    <script is:inline>
      function applyTheme() {
        const theme = (() => {
          if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
          ) {
            return localStorage.getItem("theme");
          }
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
          }
          return "light";
        })();

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
          document.documentElement.classList.remove("light");
        } else {
          document.documentElement.classList.add("light");
          document.documentElement.classList.remove("dark");
        }
      }

      // 初始加载时应用主题
      applyTheme();

      // View Transitions: 在 DOM 置换前把当前主题写入新文档
      document.addEventListener("astro:before-swap", (event) => {
        if (document.documentElement.classList.contains("dark")) {
          event.newDocument.documentElement.classList.add("dark");
          event.newDocument.documentElement.classList.remove("light");
        } else {
          event.newDocument.documentElement.classList.add("light");
          event.newDocument.documentElement.classList.remove("dark");
        }
      });

      // View Transitions 页面切换后兜底确认主题
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
  </head>
  <body class="bg-linear-to-br from-bg-base to-bg-base-end">

    <!-- 移动端顶栏 -->
    <div
      id="mobile-topbar"
      class="lg:hidden fixed top-0 left-0 right-0 z-50 glass-effect px-4 py-3 flex items-center gap-3"
    >
      <button
        id="mobile-menu-button"
        class="p-1.5 hover:bg-bg-hover-muted rounded-lg transition-colors"
        aria-label="打开菜单"
      >
        <svg
          class="w-5 h-5 text-text-primary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <a
        href="/"
        class="font-bold text-text-primary hover:text-text-accent transition-colors"
        >游戏手札</a
      >
    </div>

    <div class="flex min-h-screen">
      <!-- 左侧导航栏 - transition:persist 避免页面切换时闪烁 -->
      <aside
        id="sidebar"
        class="w-64 glass-effect fixed h-full overflow-y-auto z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-300"
        transition:persist
      >
        <div class="p-4">
          <div class="flex items-center justify-between mb-6">
            <a
              href="/"
              class="text-xl font-bold text-text-primary hover:text-text-accent transition-colors"
            >
              游戏手札
            </a>
            <div class="flex items-center gap-2">
              <ThemeToggle />
              <button
                id="close-sidebar"
                class="lg:hidden p-1 hover:bg-bg-hover-muted rounded transition-colors"
                aria-label="关闭菜单"
              >
                <svg
                  class="w-5 h-5 text-text-primary"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          </div>
          <div id="searchBtn" class="px-3 py-2 text-text-primary flex items-center gap-2 mb-4">
            <SearchIcon class="w-4 h-4" /> 点击搜索
          </div>
          <slot name="sidebar" />
        </div>
      </aside>

      <!-- 遮罩层 -->
      <div
        id="sidebar-overlay"
        class="lg:hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-30 hidden"
        transition:persist
      >
      </div>

      <!-- 右侧内容区 -->
      <main class="flex-1 lg:ml-64 p-4 md:p-8 pt-16 lg:pt-8">
        <slot />
      </main>
    </div>

    <div
      id="searchModal"
      class="fixed inset-0 z-50 hidden bg-black/50 items-start justify-center pt-20"
      role="dialog"
      aria-modal="true"
      aria-labelledby="searchModalTitle"
    >
      <div
        class="bg-white p-6 rounded-lg shadow-xl w-full max-w-2xl relative mx-4 max-h-[80vh] overflow-y-auto"
      >
        <div class="flex justify-between items-center mb-4">
          <h2 id="searchModalTitle" class="text-xl font-bold">
            搜索
          </h2>
          <button
            id="closeSearchBtn"
            aria-label="关闭搜索"
          >
            <X class="w-4 h-4" />
          </button>
        </div>
        <Search
          id="search"
          uiOptions={{ showImages: false }}
        />
      </div>
    </div>

    <script>
      let sidebarAbortController: AbortController | undefined;

      function initSidebar() {
        // 移除上一轮的事件监听器，避免 transition:persist 导致重复绑定
        sidebarAbortController?.abort();
        sidebarAbortController = new AbortController();
        const { signal } = sidebarAbortController;

        const searchBtn = document.getElementById("searchBtn");
        const searchModal = document.getElementById("searchModal");
        const closeSearchBtn = document.getElementById("closeSearchBtn");
        let lastFocusedElement: HTMLElement | null = null;

        const mobileMenuButton = document.getElementById("mobile-menu-button");
        const mobileTopbar = document.getElementById("mobile-topbar");
        const closeSidebar = document.getElementById("close-sidebar");
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebar-overlay");

        const openModal = () => {
          if (searchModal) {
            lastFocusedElement = document.activeElement as HTMLElement;
            searchModal.classList.remove("hidden");
            searchModal.classList.add("flex");
            document.body.classList.add("overflow-hidden");
            setTimeout(() => {
              const input = searchModal.querySelector("input");
              if (input) input.focus();
            }, 100);
          }
        };

        const closeModal = () => {
          if (searchModal) {
            searchModal.classList.add("hidden");
            searchModal.classList.remove("flex");
            document.body.classList.remove("overflow-hidden");

            // 恢复焦点
            if (lastFocusedElement) {
              lastFocusedElement.focus();
            }
          }
        };

        searchBtn?.addEventListener("click", openModal);
        closeSearchBtn?.addEventListener("click", closeModal);

        function openSidebar() {
          sidebar?.classList.remove("-translate-x-full");
          overlay?.classList.remove("hidden");
          mobileTopbar?.classList.add("hidden");
        }

        function closeSidebarFn() {
          sidebar?.classList.add("-translate-x-full");
          overlay?.classList.add("hidden");
          mobileTopbar?.classList.remove("hidden");
        }

        mobileMenuButton?.addEventListener("click", openSidebar, { signal });
        closeSidebar?.addEventListener("click", closeSidebarFn, { signal });
        overlay?.addEventListener("click", closeSidebarFn, { signal });

        // 点击侧边栏内任意链接后自动关闭侧边栏（仅移动端）
        sidebar?.querySelectorAll("a[href]").forEach((link) => {
          link.addEventListener(
            "click",
            () => {
              if (window.innerWidth < 1024) {
                closeSidebarFn();
              }
            },
            { signal },
          );
        });
      }

      // 初始化
      initSidebar();

      // View Transitions 后重新初始化
      document.addEventListener("astro:after-swap", initSidebar);
    </script>
  </body>
</html>
