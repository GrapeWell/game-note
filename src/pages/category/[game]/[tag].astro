---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import { getGameBanner } from '../../../utils/games';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const paths: any[] = [];
  const gameGroups: Record<string, typeof allPosts> = {};

  // 按游戏分组
  allPosts.forEach(post => {
    const game = post.data.category;
    if (!gameGroups[game]) {
      gameGroups[game] = [];
    }
    gameGroups[game].push(post);
  });

  // 为每个游戏的每个标签生成路径（按发布时间倒序）
  Object.entries(gameGroups).forEach(([game, posts]) => {
    const tagGroups: Record<string, typeof allPosts> = {};

    posts.forEach(post => {
      (post.data.tags || []).forEach(tag => {
        if (!tagGroups[tag]) {
          tagGroups[tag] = [];
        }
        tagGroups[tag].push(post);
      });
    });

    Object.entries(tagGroups).forEach(([tag, tagPosts]) => {
      paths.push({
        params: { game, tag },
        props: { posts: tagPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) }
      });
    });
  });

  return paths;
}

const { game, tag } = Astro.params;
const { posts } = Astro.props;

const gameBanner = getGameBanner(game as string);
---

<BaseLayout title={`${game} - ${tag}`}>
  <Navigation slot="sidebar" />

  <!-- F-004: 顶部展示游戏 Banner -->
  <div class="relative w-full h-44 md:h-56 rounded-xl overflow-hidden mb-8 shadow-lg">
    {gameBanner ? (
      <Image
        src={gameBanner}
        alt={game as string}
        class="w-full h-full object-cover object-top"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full bg-linear-to-br from-blue-900 via-blue-700 to-indigo-600"></div>
    )}
    <!-- 遮罩 + 标题 -->
    <div class="absolute inset-0 bg-linear-to-t from-black/75 via-black/20 to-transparent flex flex-col justify-end px-6 pb-5">
      <h1 class="text-3xl font-bold text-white drop-shadow">{game}</h1>
      <p class="text-white/70 text-sm mt-1">{tag}</p>
    </div>
  </div>

  <!-- F-004: 列表居中 -->
  <div class="max-w-5xl mx-auto">
    {posts.length === 0 ? (
      <p class="text-center text-text-faint py-16">暂无文章</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {posts.map(post => (
          <a
            href={`/posts/${post.slug}`}
            class="block ps-card border-l-3 border-l-text-accent p-5 group"
          >
            <h2 class="text-lg font-semibold text-text-primary mb-1 group-hover:text-text-accent transition-colors line-clamp-2">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-text-muted text-sm line-clamp-2 mb-3">
                {post.data.description}
              </p>
            )}
            <div class="flex items-center flex-wrap gap-2 text-xs text-text-faint mt-auto">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span>·</span>
                  <div class="flex gap-1.5">
                    {post.data.tags.map(t => (
                      <span class="px-2 py-0.5 bg-bg-muted rounded-full">{t}</span>
                    ))}
                  </div>
                </>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
