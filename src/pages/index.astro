---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import { getGameCover } from "../utils/games";

// 获取所有文章
const allPosts = await getCollection("posts", ({ data }) => !data.draft);

// 按游戏分组
const gameGroups = allPosts.reduce(
  (acc, post) => {
    const game = post.data.category;
    if (!acc[game]) {
      acc[game] = [];
    }
    acc[game].push(post);
    return acc;
  },
  {} as Record<string, typeof allPosts>,
);

// 统计信息
const totalPosts = allPosts.length;
const totalGames = Object.keys(gameGroups).length;
const allTags = new Set(allPosts.flatMap((p) => p.data.tags || []));
const totalTags = allTags.size;

// 游戏分类信息
const gameCategories = Object.entries(gameGroups).map(([game, posts]) => {
  const tags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
  return { game, postCount: posts.length, tags };
});
---

<BaseLayout title="首页 - 游戏手札">
  <Navigation slot="sidebar" />

  <div class="max-w-6xl mx-auto">
    <!-- 欢迎标题 -->
    <div class="mb-12">
      <p class="text-xl text-text-secondary">记录游戏攻略、心得</p>
    </div>

    <!-- 统计信息 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="ps-card p-6 text-center">
        <div class="text-5xl font-bold text-text-accent mb-2">
          {totalPosts}
        </div>
        <div class="text-text-secondary font-medium">篇文章</div>
      </div>
      <div class="ps-card p-6 text-center">
        <div class="text-5xl font-bold text-text-accent mb-2">
          {totalGames}
        </div>
        <div class="text-text-secondary font-medium">个游戏</div>
      </div>
      <div class="ps-card p-6 text-center">
        <div class="text-5xl font-bold text-text-accent mb-2">
          {totalTags}
        </div>
        <div class="text-text-secondary font-medium">个标签</div>
      </div>
    </div>

    <!-- 游戏分类 -->
    <div class="mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          gameCategories.map(({ game, postCount, tags }) => {
            const cover = getGameCover(game);
            return (
              <div class="ps-card p-6 group cursor-pointer relative">
                {/* 整张卡片的跳转链接（stretched link） */}
                <a
                  href={`/game/${game}`}
                  class="absolute inset-0 rounded-xl"
                  aria-label={game}
                />

                {/* 游戏封面占位区域 */}
                <div class="game-cover mb-4">
                  {cover ? (
                    <Image
                      src={cover}
                      alt={game}
                      class="absolute inset-0 w-full h-full object-cover"
                    />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="text-center">
                        <div class="text-6xl mb-2">🎮</div>
                        <div class="text-2xl font-bold text-white drop-shadow-lg">
                          {game}
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                {/* 游戏信息 */}
                <div class="mb-4">
                  <h3 class="text-2xl font-bold text-text-primary mb-2 group-hover:text-text-accent transition-colors">
                    {game}
                  </h3>
                  <p class="text-text-secondary">共 {postCount} 篇文章</p>
                </div>

                {/* 标签列表（relative + z-index 确保在 stretched link 上方可点击） */}
                <div class="relative z-10 flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <div
                      class="px-3 py-1 text-sm bg-bg-accent text-text-accent-light rounded-full hover:bg-bg-hover transition-colors"
                    >
                      {tag}
                    </div>
                  ))}
                </div>
              </div>
            );
          })
        }
      </div>
    </div>

    <!-- 快速导航 -->
    <div class="ps-card p-6">
      <h2 class="text-xl font-semibold text-text-primary mb-4">快速开始</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a
          href="/tags"
          class="flex items-center gap-3 p-4 rounded-lg hover:bg-bg-hover transition-colors"
        >
          <svg
            class="w-6 h-6 text-text-accent"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
            ></path>
          </svg>
          <div>
            <div class="font-medium text-text-primary">浏览所有标签</div>
            <div class="text-sm text-text-muted">按标签查找文章</div>
          </div>
        </a>
        <div class="flex items-center gap-3 p-4 rounded-lg">
          <svg
            class="w-6 h-6 text-text-accent"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            ></path>
          </svg>
          <div>
            <div class="font-medium text-text-primary">使用左侧导航</div>
            <div class="text-sm text-text-muted">按游戏和分类浏览</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>


