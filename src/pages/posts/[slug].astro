---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts }
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();

// 过滤出 H2 和 H3 级别的标题作为目录
const tocHeadings = headings.filter(h => h.depth <= 3);

// 获取相关文章（同标签的其他文章，最多5篇）
const relatedPosts = allPosts
  .filter(p =>
    p.slug !== post.slug &&
    p.data.tags?.some(tag => post.data.tags?.includes(tag))
  )
  .slice(0, 5);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  article={true}
  publishedTime={post.data.date}
  tags={post.data.tags}
>
  <Navigation slot="sidebar" />

  <!-- 面包屑导航 -->
  <div class="mb-6">
    <Breadcrumb
      items={[
        { label: post.data.category, href: `/game/${post.data.category}` },
        { label: post.data.title }
      ]}
    />
  </div>

  <div class="flex justify-center w-full">
    <div class="flex gap-8 max-w-7xl w-full">
      <!-- 文章内容区域 - 居中 -->
      <div class="flex-1 max-w-3xl mx-auto">
        <!-- 文章头部 -->
        <header class="mb-8">
          <h1 class="text-4xl font-bold text-text-primary mb-4">
            {post.data.title}
          </h1>
          <div class="flex items-center gap-4 text-sm text-text-secondary">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('zh-CN')}
            </time>
            <span>·</span>
            <span>{post.data.category}</span>
            {post.data.tags && (
              <>
                <span>·</span>
                <div class="flex gap-2">
                  {post.data.tags.map(tag => (
                    <a
                      href={`/tags/${tag}`}
                      class="px-2 py-1 bg-bg-muted hover:bg-bg-hover-muted rounded text-xs transition-colors"
                    >
                      {tag}
                    </a>
                  ))}
                </div>
              </>
            )}
          </div>
        </header>

        <!-- 文章内容 -->
        <article class="prose max-w-none">
          <Content />
        </article>
      </div>

      <!-- 文章目录 + 相关文章 - 固定在右侧 -->
      <aside class="hidden xl:block w-64 flex-shrink-0">
        <div class="sticky top-8 space-y-8">
          {tocHeadings.length > 0 && (
            <div>
              <h2 class="text-sm font-semibold text-text-primary mb-4">目录</h2>
              <nav class="space-y-2">
                {tocHeadings.map(heading => (
                  <a
                    href={`#${heading.slug}`}
                    class="block text-sm text-text-secondary hover:text-text-accent transition-colors"
                    style={`padding-left: ${(heading.depth - 2) * 0.75}rem`}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          {relatedPosts.length > 0 && (
            <div>
              <h2 class="text-sm font-semibold text-text-primary mb-4">相关文章</h2>
              <div class="space-y-3">
                {relatedPosts.map(related => (
                  <a
                    href={`/posts/${related.slug}`}
                    class="block p-3 bg-bg-muted hover:bg-bg-hover rounded-lg transition-colors"
                  >
                    <h3 class="text-sm font-medium text-text-primary line-clamp-2 mb-1">
                      {related.data.title}
                    </h3>
                    <div class="flex gap-1.5 flex-wrap">
                      {related.data.tags?.slice(0, 2).map(tag => (
                        <span class="text-xs text-text-secondary px-1.5 py-0.5 bg-bg-base rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      class="fixed bottom-8 right-8 p-3 bg-gradient-to-br from-blue-600 to-blue-700 text-white rounded-full shadow-lg hover:shadow-xl hover:scale-110 transition-all opacity-0 pointer-events-none"
      aria-label="返回顶部"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
  </div>
</BaseLayout>

<script>
  function initBackToTop() {
    const backToTopButton = document.getElementById('back-to-top');

    if (backToTopButton) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          backToTopButton.classList.remove('opacity-0', 'pointer-events-none');
        } else {
          backToTopButton.classList.add('opacity-0', 'pointer-events-none');
        }
      });

      backToTopButton.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  }

  // 初始化
  initBackToTop();

  // View Transitions 后重新初始化
  document.addEventListener('astro:after-swap', initBackToTop);
</script>

<style>
  /* 自定义 prose 样式以支持视频嵌入 */
  :global(.prose iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>
