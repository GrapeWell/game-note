---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getGameBanner } from '../../utils/games';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const gameGroups: Record<string, typeof allPosts> = {};

  // 按游戏分组
  allPosts.forEach(post => {
    const game = post.data.category;
    if (!gameGroups[game]) {
      gameGroups[game] = [];
    }
    gameGroups[game].push(post);
  });

  // 为每个游戏生成路径
  return Object.entries(gameGroups).map(([game, posts]) => {
    // 获取该游戏的所有标签
    const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];

    return {
      params: { game },
      props: {
        posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
        allTags
      }
    };
  });
}

const { game } = Astro.params;
const { posts, allTags } = Astro.props;

const gameBanner = getGameBanner(game as string);
---

<BaseLayout title={game as string}>
  <Navigation slot="sidebar" />

  <!-- 面包屑导航 -->
  <div class="mb-6">
    <Breadcrumb
      items={[
        { label: game as string }
      ]}
    />
  </div>

  <!-- 游戏 Banner -->
  <div class="relative w-full h-44 md:h-56 rounded-xl overflow-hidden mb-8 shadow-lg">
    {gameBanner ? (
      <Image
        src={gameBanner}
        alt={game as string}
        class="w-full h-full object-cover object-top"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full bg-linear-to-br from-blue-900 via-blue-700 to-indigo-600"></div>
    )}
    <!-- 遮罩 + 标题 -->
    <div class="absolute inset-0 bg-linear-to-t from-black/75 via-black/20 to-transparent flex flex-col justify-end px-6 pb-5">
      <h1 class="text-3xl font-bold text-white drop-shadow">{game}</h1>
      <p class="text-white/70 text-sm mt-1">共 {posts.length} 篇文章</p>
    </div>
  </div>

  <!-- 文章列表 -->
  <div class="max-w-5xl mx-auto">
    <!-- 标签筛选器 -->
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-5 h-5 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        <h2 class="text-sm font-semibold text-text-primary">筛选标签</h2>
      </div>

      <div class="flex flex-wrap gap-2" id="tag-filter">
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="px-3 py-1.5 rounded-lg text-sm transition-all bg-bg-muted text-text-secondary hover:bg-bg-hover hover:text-text-primary"
          >
            {tag}
          </button>
        ))}
      </div>
    </div>

    <!-- 文章数量提示 -->
    <div id="result-count" class="mb-4 text-sm text-text-secondary hidden">
    </div>

    <!-- 文章列表 -->
    <div id="posts-container">
      {posts.length === 0 ? (
        <p class="text-center text-text-faint py-16">暂无文章</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {posts.map(post => (
            <a
              href={`/posts/${post.slug}`}
              class="post-item block ps-card border-l-3 border-l-text-accent p-5 group"
              data-tags={post.data.tags?.join(',') || ''}
            >
              <h2 class="text-lg font-semibold text-text-primary mb-1 group-hover:text-text-accent transition-colors line-clamp-2">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-text-muted text-sm line-clamp-2 mb-3">
                  {post.data.description}
                </p>
              )}
              <div class="flex items-center flex-wrap gap-2 text-xs text-text-faint mt-auto">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <div class="flex gap-1.5">
                      {post.data.tags.map(t => (
                        <span class="px-2 py-0.5 bg-bg-muted rounded-full">{t}</span>
                      ))}
                    </div>
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  function initTagFilter() {
    const tagButtons = document.querySelectorAll<HTMLButtonElement>('[data-tag]');
    const resultCount = document.getElementById('result-count');
    const postItems = document.querySelectorAll<HTMLElement>('.post-item');

    let selectedTags: string[] = [];

    function updateFilter() {
      let visibleCount = 0;

      postItems.forEach(item => {
        const postTags = item.dataset.tags?.split(',').filter(Boolean) || [];

        // 如果没有选中任何标签，显示所有文章
        if (selectedTags.length === 0) {
          item.style.display = '';
          visibleCount++;
        } else {
          // 检查文章是否包含所有选中的标签
          const matches = selectedTags.every(tag => postTags.includes(tag));
          item.style.display = matches ? '' : 'none';
          if (matches) visibleCount++;
        }
      });

      // 更新结果计数
      if (selectedTags.length > 0) {
        resultCount!.textContent = `找到 ${visibleCount} 篇文章`;
        resultCount!.classList.remove('hidden');
      } else {
        resultCount!.classList.add('hidden');
      }

      // 更新标签按钮样式
      tagButtons.forEach(button => {
        const tag = button.dataset.tag!;
        if (selectedTags.includes(tag)) {
          button.className = 'px-3 py-1.5 rounded-lg text-sm transition-all bg-text-accent text-white font-medium shadow-md';
        } else {
          button.className = 'px-3 py-1.5 rounded-lg text-sm transition-all bg-bg-muted text-text-secondary hover:bg-bg-hover hover:text-text-primary';
        }
      });
    }

    // 标签点击事件
    tagButtons.forEach(button => {
      button.addEventListener('click', () => {
        const tag = button.dataset.tag!;
        const index = selectedTags.indexOf(tag);

        if (index > -1) {
          // 取消选中
          selectedTags.splice(index, 1);
        } else {
          // 选中
          selectedTags.push(tag);
        }

        updateFilter();
      });
    });
  }

  // 初始化
  initTagFilter();

  // View Transitions 后重新初始化
  document.addEventListener('astro:after-swap', initTagFilter);
</script>
