---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';

// 获取所有文章
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// 统计所有标签及其文章数量
const tagCounts: Record<string, number> = {};
allPosts.forEach(post => {
  (post.data.tags || []).forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

// 按文章数量排序
const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="所有标签 - 游戏手札" description="浏览所有文章标签">
  <Navigation slot="sidebar" />

  <div class="max-w-5xl">
    <h1 class="text-4xl font-bold text-text-primary mb-8">所有标签</h1>

    <div class="flex flex-wrap gap-4">
      {sortedTags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="group relative px-6 py-3 ps-card"
        >
          <div class="flex items-center gap-2">
            <span class="text-lg font-medium text-text-primary group-hover:text-text-accent transition-colors">
              {tag}
            </span>
            <span class="px-2 py-1 text-xs font-semibold text-text-muted bg-bg-muted rounded-full">
              {count}
            </span>
          </div>
        </a>
      ))}
    </div>

    {sortedTags.length === 0 && (
      <p class="text-text-secondary">暂无标签</p>
    )}
  </div>
</BaseLayout>
